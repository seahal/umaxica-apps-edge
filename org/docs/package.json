{
  "name": "umaxica-apps-edge-org-docs",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "opennextjs-cloudflare build",
    "build:next": "next build",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "deploy:upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "deploy:promote": "wrangler versions deploy --yes",
    "dev": "next dev --hostname 0.0.0.0 --port 5306",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.19.11",
    "@sentry/nextjs": "^10.51.0",
    "next": "^16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260523.0",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "wrangler": "^4.93.0"
  }
}
