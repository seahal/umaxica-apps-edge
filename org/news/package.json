{
  "name": "umaxica-apps-edge-org-news",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vp exec opennextjs-cloudflare build",
    "build:next": "next build",
    "cf-typegen": "vp exec wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts",
    "deploy": "vp exec opennextjs-cloudflare build && vp exec opennextjs-cloudflare deploy",
    "deploy:upload": "vp exec opennextjs-cloudflare build && vp exec opennextjs-cloudflare upload",
    "deploy:promote": "vp exec wrangler versions deploy --yes",
    "dev": "next dev --hostname 0.0.0.0 --port 5307",
    "preview": "vp exec opennextjs-cloudflare build && vp exec opennextjs-cloudflare preview",
    "type": "vp exec tsgo --noEmit"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.19.11",
    "next": "^16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260530.1",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "vite-plus": "catalog:",
    "wrangler": "^4.93.0"
  }
}
