{
  "name": "umaxica-apps-edge-com-apex",
  "type": "module",
  "scripts": {
    "server": "vp dev",
    "build": "vp build --ssr src/index.tsx && rm -rf dist/client && mkdir -p dist/client && cp -a public/. dist/client/",
    "preview": "$npm_execpath run build && vp preview",
    "deploy": "$npm_execpath run build && wrangler deploy",
    "deploy:upload": "$npm_execpath run build && wrangler versions upload",
    "deploy:promote": "wrangler versions deploy --yes",
    "cf-typegen": "pnpm wrangler types --env-interface CloudflareBindings",
    "type": "pnpm run cf-typegen && pnpm exec tsgo --noEmit"
  },
  "dependencies": {
    "hono": "^4.12.5"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.26.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^19.2.14",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vite-ssr-components": "^0.5.2",
    "wrangler": "^4.71.0"
  }
}
