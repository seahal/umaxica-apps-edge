{
  "name": "umaxica-apps-edge-app-core",
  "version": "0.1.0",
  "private": true,
  "description": "code for xx.umaxica.app",
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "typegen": "react-router typegen",
    "cf-typegen": "pnpm wrangler types",
    "deploy": "CLOUDFLARE_ENV=production pnpm run build && CLOUDFLARE_ENV=production pnpm exec wrangler deploy",
    "deploy:upload": "CLOUDFLARE_ENV=production pnpm run build && CLOUDFLARE_ENV=production pnpm exec wrangler versions upload",
    "deploy:promote": "pnpm exec wrangler versions deploy --yes",
    "server": "CLOUDFLARE_ENV=development react-router dev",
    "postinstall": "pnpm run cf-typegen || true",
    "preview": "pnpm run build && vp preview",
    "type": "pnpm run cf-typegen && vp exec tsc -b"
  },
  "dependencies": {
    "i18next": "^25.8.13",
    "isbot": "^5.1.35",
    "nuqs": "^2.6.0",
    "react": "^19.2.4",
    "react-aria-components": "^1.15.1",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.5.4",
    "react-router": "^7.13.1",
    "react-router-dom": "^7.13.1",
    "remix-i18next": "^7.4.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@babel/preset-typescript": "^7.28.5",
    "@cloudflare/vite-plugin": "^1.25.6",
    "@react-router/dev": "^7.13.1",
    "@react-router/node": "^7.13.1",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "babel-plugin-react-compiler": "^1.0.0",
    "happy-dom": "^20.8.8",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "catalog:",
    "wrangler": "^4.76.0"
  }
}
