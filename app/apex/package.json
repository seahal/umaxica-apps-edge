{
  "name": "umaxica-apps-edge-app-apex",
  "type": "module",
  "scripts": {
    "server": "vp dev",
    "build": "vp build && sh -c 'mkdir -p dist/client/src && cp dist/client/assets/style-*.css dist/client/src/style.css'",
    "preview": "vp run build && vp preview",
    "deploy": "vp run build && vp exec wrangler deploy",
    "deploy:upload": "vp run build && vp exec wrangler versions upload",
    "deploy:promote": "vp exec wrangler versions deploy --yes",
    "cf-typegen": "vp exec wrangler types --env-interface CloudflareBindings",
    "type": "vp run cf-typegen && vp exec tsc --noEmit"
  },
  "dependencies": {
    "@hono/structured-logger": "catalog:",
    "hono": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "catalog:",
    "@cloudflare/workers-types": "catalog:",
    "@tailwindcss/vite": "catalog:",
    "@types/react": "catalog:",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.14",
    "semgrep": "^0.0.1",
    "tailwindcss": "catalog:",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vite-ssr-components": "^0.5.2",
    "wrangler": "catalog:"
  }
}
