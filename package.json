{
  "name": "umaxica-app-edge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint --type-aware --fix .",
    "lint:check": "oxlint --type-aware .",
    "deploy:app-docs:upload": "pnpm --filter umaxica-apps-edge-app-docs run deploy:upload",
    "deploy:com-docs:upload": "pnpm --filter umaxica-apps-edge-com-docs run deploy:upload",
    "deploy:org-docs:upload": "pnpm --filter umaxica-apps-edge-org-docs run deploy:upload",
    "typecheck": "pnpm --filter umaxica-apps-edge-app-core --filter umaxica-apps-edge-app-docs --filter umaxica-apps-edge-app-help --filter umaxica-apps-edge-app-news --filter umaxica-apps-edge-com-core --filter umaxica-apps-edge-com-docs --filter umaxica-apps-edge-com-help --filter umaxica-apps-edge-com-news --filter umaxica-apps-edge-dev-acme --filter umaxica-apps-edge-org-core --filter umaxica-apps-edge-org-docs --filter umaxica-apps-edge-org-help --filter umaxica-apps-edge-org-news run typecheck",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.1",
    "@typescript/native-preview": "7.0.0-dev.20260619.1",
    "@vitest/coverage-v8": "4.1.10",
    "dependency-cruiser": "^17.4.3",
    "happy-dom": "^20.10.6",
    "knip": "^6.26.0",
    "lefthook": "^2.1.10",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "oxlint-tsgolint": "^0.24.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "catalog:",
    "wrangler": "^4.110.0"
  },
  "packageManager": "pnpm@10.29.3",
  "pnpm": {
    "overrides": {
      "minimatch": ">=10.2.3",
      "fast-xml-parser": "5.3.8",
      "ajv": ">=8.18.0"
    },
    "ignoredBuiltDependencies": [
      "@sentry/cli",
      "esbuild",
      "sharp",
      "workerd"
    ]
  }
}
