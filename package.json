{
  "name": "umaxica-apps-edge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "build:apex:check": "XDG_CONFIG_HOME=${XDG_CONFIG_HOME:-/tmp} vp run --filter ./app/apex --filter ./com/apex --filter ./net/apex --filter ./org/apex build",
    "deploy": "pnpm --dir app/core run deploy",
    "deploy:upload": "pnpm --dir app/core run deploy:upload",
    "deploy:promote": "pnpm --dir app/core run deploy:promote",
    "type": "pnpm -r --if-present run type",
    "typecheck": "pnpm run type",
    "prepare": "vp config"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.0",
    "hono": "catalog:",
    "jose": "^6.2.2",
    "tailwindcss": "catalog:"
  },
  "devDependencies": {
    "@babel/preset-typescript": "^7.28.5",
    "@cloudflare/vite-plugin": "catalog:",
    "@cloudflare/workers-types": "catalog:",
    "@tailwindcss/vite": "catalog:",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "4.1.5",
    "babel-plugin-react-compiler": "^1.0.0",
    "gitleaks": "^1.0.0",
    "happy-dom": "^20.9.0",
    "knip": "^6.7.0",
    "miniflare": "^4.20260424.0",
    "preact-render-to-string": "^6.6.7",
    "vite-plugin-babel": "^1.6.0",
    "vite-plus": "catalog:",
    "vite-ssr-components": "^0.5.2",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "catalog:",
    "wrangler": "catalog:"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
