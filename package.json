{
  "name": "umaxica-app-edge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "format": "vp fmt",
    "formach:check": "vp fmt --check",
    "lint": "vp lint --fix",
    "lint:check": "vp lint",
    "deploy:app-docs:upload": "vp run --filter umaxica-apps-edge-app-docs deploy:upload",
    "deploy:com-docs:upload": "vp run --filter umaxica-apps-edge-com-docs deploy:upload",
    "deploy:org-docs:upload": "vp run --filter umaxica-apps-edge-org-docs deploy:upload",
    "type": "vp run --filter umaxica-apps-edge-app-docs --filter umaxica-apps-edge-app-help --filter umaxica-apps-edge-app-news --filter umaxica-apps-edge-com-docs --filter umaxica-apps-edge-com-help --filter umaxica-apps-edge-com-news --filter umaxica-apps-edge-dev-acme --filter umaxica-apps-edge-org-docs --filter umaxica-apps-edge-org-help --filter umaxica-apps-edge-org-news type",
    "typecheck": "vp run type",
    "test": "vp test run",
    "test:cov": "vp test run --coverage",
    "prepare": "vp config"
  },
  "devDependencies": {
    "@babel/preset-typescript": "^8.0.1",
    "@cloudflare/vite-plugin": "^1.42.1",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.0.0",
    "@typescript/native-preview": "7.0.0-dev.20260619.1",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "4.1.9",
    "babel-plugin-react-compiler": "^1.0.0",
    "dependency-cruiser": "^17.4.3",
    "happy-dom": "^20.10.6",
    "knip": "^6.17.1",
    "miniflare": "^4.20260617.1",
    "vite-plugin-babel": "^1.7.3",
    "vite-plus": "catalog:",
    "vite-ssr-components": "^0.6.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "catalog:",
    "wrangler": "^4.103.0"
  },
  "packageManager": "pnpm@10.29.3",
  "pnpm": {
    "overrides": {
      "minimatch": ">=10.2.3",
      "fast-xml-parser": "5.3.8",
      "ajv": ">=8.18.0"
    },
    "ignoredBuiltDependencies": [
      "@sentry/cli",
      "esbuild",
      "sharp",
      "workerd"
    ]
  }
}
