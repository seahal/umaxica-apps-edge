{
  "name": "umaxica-apps-edge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "build:apex:check": "XDG_CONFIG_HOME=${XDG_CONFIG_HOME:-/tmp} vp run --filter ./app/apex --filter ./com/apex --filter ./net/apex --filter ./org/apex build",
    "type": "pnpm -r --if-present --filter ./app/apex --filter ./app/core --filter ./com/apex --filter ./com/core --filter ./org/apex --filter ./org/core --filter ./net/apex run type",
    "typecheck": "pnpm run type",
    "prepare": "vp config"
  },
  "dependencies": {
    "hono": "^4.12.9",
    "jose": "^6.2.2",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@babel/preset-typescript": "^7.28.5",
    "@cloudflare/vite-plugin": "^1.30.1",
    "@react-router/cloudflare": "^7.13.2",
    "@sentry/react-router": "^10.46.0",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.0",
    "@vercel/react-router": "^1.2.6",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "4.1.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "gitleaks": "^1.0.0",
    "happy-dom": "^20.8.9",
    "knip": "^6.0.6",
    "miniflare": "^4.20260317.2",
    "vite-plugin-babel": "^1.6.0",
    "vite-plus": "catalog:",
    "vite-ssr-components": "^0.5.2",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "npm:@voidzero-dev/vite-plus-test@^0.1.14",
    "wrangler": "^4.77.0"
  },
  "packageManager": "pnpm@10.32.1"
}
