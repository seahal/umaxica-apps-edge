{
  "name": "umaxica-apps-edge-apex-net",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --config wrangler.jsonc --port 5201 --ip 0.0.0.0",
    "build": "wrangler deploy --config wrangler.jsonc --dry-run --outdir dist",
    "preview": "pnpm run build && wrangler dev --config wrangler.jsonc --local --ip 0.0.0.0",
    "deploy": "wrangler deploy --config wrangler.jsonc",
    "deploy:upload": "wrangler versions upload --config wrangler.jsonc",
    "deploy:promote": "wrangler versions deploy --config wrangler.jsonc --yes",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "hono": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "catalog:",
    "wrangler": "catalog:"
  }
}
