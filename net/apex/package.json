{
  "name": "umaxica-apps-edge-net-apex",
  "type": "module",
  "scripts": {
    "server": "vp dev",
    "build": "vp build && sh -c 'mkdir -p dist/client/src && cp dist/client/assets/style-*.css dist/client/src/style.css'",
    "preview": "$npm_execpath run build && vp preview",
    "deploy": "$npm_execpath run build && wrangler deploy",
    "deploy:upload": "$npm_execpath run build && wrangler versions upload",
    "deploy:promote": "wrangler versions deploy --yes",
    "cf-typegen": "pnpm wrangler types --env-interface CloudflareBindings",
    "type": "pnpm run cf-typegen && vp exec tsc --noEmit"
  },
  "dependencies": {
    "@hono/structured-logger": "catalog:",
    "hono": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "catalog:",
    "@cloudflare/workers-types": "catalog:",
    "@tailwindcss/vite": "catalog:",
    "@types/react": "catalog:",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.10",
    "tailwindcss": "catalog:",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vite-ssr-components": "^0.5.2",
    "wrangler": "catalog:"
  }
}
